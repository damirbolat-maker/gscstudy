Options -Indexes

# Pretty URLs for static HTML
RewriteEngine On

# If request is a real file or directory, serve it
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Map /admin -> /admin.html
RewriteRule ^admin/?$ admin.html [L]

# Map /tests -> /tests.html
RewriteRule ^tests/?$ tests.html [L]

# Map /courses -> /courses.html
RewriteRule ^courses/?$ courses.html [L]

# Map /abroad -> /abroad.html
RewriteRule ^abroad/?$ abroad.html [L]
